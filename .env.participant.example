# Copia este archivo a .env.local y edítalo antes de arrancar el participante.
# .env.local está en .gitignore y nunca se sube al repo.

# Índice de este participante en la tanda (0, 1 o 2)
SK_IDX=0

# Semilla de la clave privada — elige un string largo y aleatorio.
# En mainnet usa: python3 -c "import secrets; print(secrets.token_hex(32))"
SK_SEED=cambia-esto-por-algo-secreto

# URL del nodo Bitcoin Core (el que corre en PC-A)
BITCOIND_RPC_URL=http://user:password@192.168.1.10:18443

# Puerto de escucha (opcional, default 8080)
# PORT=8080
